{
    "compilerOptions": {
        "target": "ES2022",
        "module": "Node16",
        "lib": [
            "ES2022"
        ],
        "outDir": "./dist/main",
        "rootDir": "./src",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "declaration": false,
        "declarationMap": false,
        "sourceMap": false,
        "removeComments": true,
        "moduleResolution": "Node16",
        "paths": {
            "@main/*": ["./src/main/*"]
        }
    },
    "include": [
        "src/main/**/*",
        "src/preload/**/*"
    ]
}
